  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogue:
    name: Fine Shyt
    sentences:
    - While you're looking for me, let me put you on this song I recently found.
    - OH! Better yet... LET'S PLAY A GAME!
    - So you know how there are objects ahead of you?
    - Why don't you skate to the beat of the song?
    - Let's try out some easy examples to start off.
